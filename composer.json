{
	"name": "detain/myadmin-kayako-chat",
	"type": "myadmin-plugin",
	"description": "Kayako handling plugin for MyAdmin",
	"keywords": [
		"abuse",
		"administration",
		"spam"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https:\/\/my.interserver.net\/"
		}
	],
	"config": {
		"bin-dir": "vendor\/bin",
		"minimum-stability": "dev"
	},
	"require": {
		"php": ">=5.0.0",
		"ext-soap": "*",
		"symfony/event-dispatcher": "*@stable",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminKayakoChat\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminKayakoChat\\Tests\\": "tests/"
		}
	}
}
